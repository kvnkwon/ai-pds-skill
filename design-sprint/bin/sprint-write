#!/usr/bin/env bash
set -euo pipefail

# sprint-write: Append a section to sprint-output.md and update frontmatter
# Usage: sprint-write <sprint-file> <stage-number> <section-content>
#        sprint-write <sprint-file> append-assumption <pipe-delimited-value>
#        sprint-write <sprint-file> append-quote <pipe-delimited-value>
# The section content is read from stdin if not provided as argument 3

SPRINT_FILE="${1:?Usage: sprint-write <sprint-file> <stage-number|append-assumption|append-quote> <content>}"
ACTION="${2:?Usage: sprint-write <sprint-file> <stage-number|append-assumption|append-quote> <content>}"

# Validate that SPRINT_FILE path is absolute
case "$SPRINT_FILE" in
  /*)
    ;; # absolute path — OK
  *)
    echo "ERROR: SPRINT_FILE path must be absolute. Got: $SPRINT_FILE" >&2
    exit 1
    ;;
esac

if [ ! -f "$SPRINT_FILE" ]; then
  echo "ERROR: Sprint file not found: $SPRINT_FILE" >&2
  exit 1
fi

# Check write permission
if [ ! -w "$SPRINT_FILE" ]; then
  echo "ERROR: No write permission to $SPRINT_FILE" >&2
  exit 1
fi

# ── Array append operations ──────────────────────────────────────────────
# Appends a pipe-delimited entry to a multi-line YAML array in frontmatter.
# Format: key:\n  - "value1"\n  - "value2"
append_to_yaml_array() {
  local key="$1"
  local value="$2"
  local file="$3"

  # Check if key exists in frontmatter
  if ! sed -n '/^---$/,/^---$/p' "$file" | grep -q "^${key}:"; then
    # Key missing (v1 sprint) — insert it before the closing ---
    # Use awk to insert the key + first entry before the second ---
    awk -v key="$key" -v val="$value" '
      BEGIN { count=0 }
      /^---$/ { count++ }
      count==2 && !inserted {
        print key ":"
        print "  - \"" val "\""
        inserted=1
      }
      { print }
    ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
  else
    # Key exists — find it and append after last existing entry (or right after key if empty)
    awk -v key="$key" -v val="$value" '
      /^---$/ { fm_delim++ }
      fm_delim == 1 {
        if ($0 ~ "^" key ":") {
          found_key = 1
          print
          next
        }
        if (found_key && /^  - /) {
          print
          next
        }
        if (found_key && !/^  - /) {
          # End of array (or empty array) — insert before this line
          print "  - \"" val "\""
          found_key = 0
          inserted = 1
          print
          next
        }
      }
      # Handle case where key is last before closing ---
      fm_delim == 2 && found_key && !inserted {
        print "  - \"" val "\""
        found_key = 0
        inserted = 1
      }
      { print }
    ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
  fi

  # Update timestamp
  local NOW
  NOW=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  sed -i '' "s/updated_at: .*/updated_at: $NOW/" "$file" 2>/dev/null || \
  sed -i "s/updated_at: .*/updated_at: $NOW/" "$file" 2>/dev/null
}

# ── Handle append operations ─────────────────────────────────────────────
case "$ACTION" in
  append-assumption)
    VALUE="${3:?Usage: sprint-write <file> append-assumption <value>}"
    append_to_yaml_array "assumptions" "$VALUE" "$SPRINT_FILE"
    echo "APPENDED: assumption"
    exit 0
    ;;
  append-quote)
    VALUE="${3:?Usage: sprint-write <file> append-quote <value>}"
    append_to_yaml_array "quotes" "$VALUE" "$SPRINT_FILE"
    echo "APPENDED: quote"
    exit 0
    ;;
esac

# ── Stage write operation (original behavior) ────────────────────────────
STAGE_NUM="$ACTION"

# Validate stage_number is 1-9
if ! echo "$STAGE_NUM" | grep -qE '^[1-9]$'; then
  echo "ERROR: Invalid stage number '$STAGE_NUM'. Must be an integer from 1 to 9." >&2
  exit 1
fi

# Read content from argument or stdin
if [ -n "${3:-}" ]; then
  CONTENT="$3"
else
  CONTENT=$(cat)
fi

# Append section content
printf "\n%s\n" "$CONTENT" >> "$SPRINT_FILE"

# Update stages_completed in frontmatter
# Read current stages
CURRENT=$(sed -n '/^---$/,/^---$/p' "$SPRINT_FILE" | grep 'stages_completed:' | sed 's/stages_completed: *\[//' | sed 's/\]//' | tr -d ' ')

if [ -z "$CURRENT" ]; then
  NEW_STAGES="$STAGE_NUM"
else
  # Add new stage if not already present
  if echo ",$CURRENT," | grep -q ",$STAGE_NUM,"; then
    NEW_STAGES="$CURRENT"
  else
    NEW_STAGES="$CURRENT, $STAGE_NUM"
  fi
fi

# Update frontmatter in place
if command -v sed &>/dev/null; then
  sed -i '' "s/stages_completed: *\[.*\]/stages_completed: [$NEW_STAGES]/" "$SPRINT_FILE" 2>/dev/null || \
  sed -i "s/stages_completed: *\[.*\]/stages_completed: [$NEW_STAGES]/" "$SPRINT_FILE" 2>/dev/null

  # Verify that stages_completed was actually updated
  VERIFY_STAGES=$(sed -n '/^---$/,/^---$/p' "$SPRINT_FILE" | grep 'stages_completed:' | sed 's/stages_completed: *\[//' | sed 's/\]//' | tr -d ' ')
  if ! echo ",$VERIFY_STAGES," | grep -q ",$STAGE_NUM,"; then
    echo "WARNING: Failed to update stages_completed in frontmatter. The frontmatter may be malformed." >&2
  fi

  # Update timestamp
  NOW=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  sed -i '' "s/updated_at: .*/updated_at: $NOW/" "$SPRINT_FILE" 2>/dev/null || \
  sed -i "s/updated_at: .*/updated_at: $NOW/" "$SPRINT_FILE" 2>/dev/null

  # Verify timestamp was updated
  VERIFY_TS=$(sed -n '/^---$/,/^---$/p' "$SPRINT_FILE" | grep 'updated_at:' || true)
  if [ -z "$VERIFY_TS" ]; then
    echo "WARNING: Failed to update updated_at timestamp in frontmatter." >&2
  fi
fi

echo "WRITTEN: Stage $STAGE_NUM"
