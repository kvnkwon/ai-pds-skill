#!/usr/bin/env bash
set -euo pipefail

# sprint-export: Generate export files from sprint-output.md
# Usage: sprint-export <sprint-file>
# v1: Generates product-context.md, claude-code-starter.md, pitch-summary.md
# v2: Generates product-context.md (with quote wall + elevator pitch), pitch-summary.md

SPRINT_FILE="${1:?Usage: sprint-export <sprint-file>}"

if [ ! -f "$SPRINT_FILE" ]; then
  echo "ERROR: Sprint file not found: $SPRINT_FILE" >&2
  exit 1
fi

SPRINT_DIR=$(dirname "$SPRINT_FILE")

# Extract frontmatter
FRONTMATTER=$(sed -n '/^---$/,/^---$/p' "$SPRINT_FILE")
STAGES=$(echo "$FRONTMATTER" | grep 'stages_completed:' | sed 's/stages_completed: *\[//' | sed 's/\]//' | tr -d ' ')
STAGE_COUNT=$(echo "$STAGES" | tr ',' '\n' | grep -c '[0-9]' 2>/dev/null || echo "0")

# Detect sprint version (default to 1 if missing)
SPRINT_VERSION=$(echo "$FRONTMATTER" | grep 'sprint_version:' | sed 's/sprint_version: *//' || true)
if [ -z "$SPRINT_VERSION" ]; then
  SPRINT_VERSION="1"
fi

if [ "$STAGE_COUNT" -lt 5 ]; then
  echo "WARNING: Only $STAGE_COUNT of 9 stages completed. Exports may be incomplete." >&2
fi

# Extract content (everything after the closing --- of YAML frontmatter)
FRONTMATTER_END=$(awk '/^---$/{n++; if(n==2){print NR; exit}}' "$SPRINT_FILE")
if [ -n "$FRONTMATTER_END" ]; then
  CONTENT=$(tail -n +"$((FRONTMATTER_END + 1))" "$SPRINT_FILE")
else
  CONTENT=$(cat "$SPRINT_FILE")
fi

# ── Helpers ──────────────────────────────────────────────────────────────
extract_section() {
  local num="$1"
  awk -v n="$num" '
    /^## *[0-9]+\./ {
      s = $0; sub(/^## */, "", s); sub(/\..*/, "", s); sec = s+0
      if (sec == n) { capture = 1; next }
      if (capture) { exit }
      next
    }
    capture { print }
  ' <<< "$CONTENT"
}

extract_field() {
  local num="$1"
  local pattern="$2"
  extract_section "$num" | awk -v pat="$pattern" '
    /^\*\*/ {
      low = tolower($0)
      lpat = tolower(pat)
      if (index(low, lpat) > 0) {
        capture = 1
        print
        next
      }
      if (capture) exit
    }
    capture { print }
  '
}

# Extract quotes from YAML frontmatter (pipe-delimited: text|source|stage)
extract_quotes() {
  sed -n '/^---$/,/^---$/p' "$SPRINT_FILE" | awk '
    /^quotes:/ { in_quotes = 1; next }
    in_quotes && /^  - "/ {
      line = $0
      sub(/^  - "/, "", line)
      sub(/"$/, "", line)
      print line
    }
    in_quotes && !/^  - / && !/^quotes:/ { exit }
  '
}

# ── Version-specific exports ─────────────────────────────────────────────

if [ "$SPRINT_VERSION" = "1" ]; then
  # ══ v1 EXPORT (original behavior) ═════════════════════════════════════

  # 1. product-context.md
  {
  cat << 'HEADER'
# Product Context

Generated by Design Sprint Assistant
Use this file to give Claude Code full context on what to build.

---

HEADER
  echo "$CONTENT"
  NOT_V1=$(extract_field 6 "Explicitly NOT")
  if [ -n "$NOT_V1" ]; then
    printf '\n---\n\n## What NOT to Build\n\n'
    echo "$NOT_V1"
  fi
  } > "$SPRINT_DIR/product-context.md"
  echo "EXPORTED: $SPRINT_DIR/product-context.md"

  # 2. claude-code-starter.md
  {
  cat << 'EOF'
# Claude Code Starter

Read `product-context.md` for full context on the product. Then follow
this implementation plan.

EOF
  PROBLEM=$(extract_section 2)
  if [ -n "$PROBLEM" ]; then
    printf '## Problem\n\n%s\n\n' "$PROBLEM"
  fi
  MVP_FEATURES=$(extract_field 6 "must-have")
  NOT_V1_STARTER=$(extract_field 6 "Explicitly NOT")
  if [ -n "$MVP_FEATURES" ]; then
    printf '## MVP Features\n\n%s\n\n' "$MVP_FEATURES"
  fi
  if [ -n "$NOT_V1_STARTER" ]; then
    printf '## Out of Scope (v1)\n\n%s\n\n' "$NOT_V1_STARTER"
  fi
  TECH_STACK=$(extract_field 7 "Tech stack")
  if [ -n "$TECH_STACK" ]; then
    printf '## Tech Stack\n\n%s\n\n' "$TECH_STACK"
  fi
  BUILD_ORDER=$(extract_field 7 "Build order")
  if [ -n "$BUILD_ORDER" ]; then
    printf '## Build Order\n\n%s\n\n' "$BUILD_ORDER"
  fi
  ASSUMPTIONS=$(extract_section 8)
  if [ -n "$ASSUMPTIONS" ]; then
    printf '## Assumptions & Risks\n\n%s\n\n' "$ASSUMPTIONS"
  fi
  SESSION_PLAN=$(extract_field 9 "First coding session")
  if [ -n "$SESSION_PLAN" ]; then
    printf '## First Session Plan\n\n%s\n\n' "$SESSION_PLAN"
  fi
  EXTRA_CONTEXT=$(extract_field 9 "Additional context")
  if [ -n "$EXTRA_CONTEXT" ]; then
    printf '## Additional Context\n\n%s\n\n' "$EXTRA_CONTEXT"
  fi
  cat << 'EOF'
## Instructions

1. Read product-context.md thoroughly before writing any code
2. Follow the Build Order above
3. Start with the First Session Plan
4. After each major component, check back against the MVP Features
5. Do NOT build anything listed in "Out of Scope (v1)"

## Priorities

- Get the magic moment working first
- Ship something usable, then iterate
- When in doubt, ask — don't assume

EOF
  } > "$SPRINT_DIR/claude-code-starter.md"
  echo "EXPORTED: $SPRINT_DIR/claude-code-starter.md"

  # 3. pitch-summary.md
  {
  cat << 'HEADER'
# Pitch Summary

One-page summary generated by Design Sprint Assistant.

---

HEADER
  SEC2=$(extract_section 2)
  printf '## The Problem\n\n'
  if [ -n "$SEC2" ]; then echo "$SEC2"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC4=$(extract_section 4)
  printf '## The Solution\n\n'
  if [ -n "$SEC4" ]; then echo "$SEC4"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC5=$(extract_section 5)
  printf '## The Market\n\n'
  if [ -n "$SEC5" ]; then echo "$SEC5"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC6=$(extract_section 6)
  printf '## The MVP\n\n'
  if [ -n "$SEC6" ]; then echo "$SEC6"; else echo "_See product-context.md_"; fi
  } > "$SPRINT_DIR/pitch-summary.md"
  echo "EXPORTED: $SPRINT_DIR/pitch-summary.md"

else
  # ══ v2 EXPORT ══════════════════════════════════════════════════════════

  # 1. product-context.md (with quote wall + elevator pitch, no claude-code-starter)
  {
  cat << 'HEADER'
# Product Context

Generated by Design Sprint Assistant (v2)
Use this file to give Claude Code full context on what to build.

---

HEADER
  echo "$CONTENT"

  # Quote Wall — aggregate quotes from YAML frontmatter
  QUOTES=$(extract_quotes)
  if [ -n "$QUOTES" ]; then
    printf '\n---\n\n## Quote Wall\n\nReal quotes collected during research:\n\n'
    echo "$QUOTES" | while IFS='|' read -r text source stage; do
      printf '> "%s"\n> — %s (Stage %s)\n\n' "$text" "$source" "$stage"
    done
  fi

  # Elevator Pitch — synthesized from sprint content
  printf '\n---\n\n## Elevator Pitch\n\n'
  printf '_Generate a 30-second pitch from the sprint context above._\n'
  printf '_Covers: problem, who, solution, why now, magic moment._\n'

  } > "$SPRINT_DIR/product-context.md"
  echo "EXPORTED: $SPRINT_DIR/product-context.md"

  # 2. pitch-summary.md (v2 section numbers)
  {
  cat << 'HEADER'
# Pitch Summary

One-page summary generated by Design Sprint Assistant (v2).

---

HEADER
  # v2 sections: 2=Problems, 4=Ideation, 5=Market, 6=Features
  SEC2=$(extract_section 2)
  printf '## The Problem\n\n'
  if [ -n "$SEC2" ]; then echo "$SEC2"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC4=$(extract_section 4)
  printf '## The Solution\n\n'
  if [ -n "$SEC4" ]; then echo "$SEC4"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC5=$(extract_section 5)
  printf '## The Market\n\n'
  if [ -n "$SEC5" ]; then echo "$SEC5"; else echo "_See product-context.md_"; fi
  printf '\n'
  SEC6=$(extract_section 6)
  printf '## The Features\n\n'
  if [ -n "$SEC6" ]; then echo "$SEC6"; else echo "_See product-context.md_"; fi
  } > "$SPRINT_DIR/pitch-summary.md"
  echo "EXPORTED: $SPRINT_DIR/pitch-summary.md"

  # No claude-code-starter.md for v2 (sprint is about what/why, not how)
fi

echo "DONE: All exports generated in $SPRINT_DIR"
