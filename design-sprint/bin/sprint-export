#!/usr/bin/env bash
set -euo pipefail

# sprint-export: Generate export files from sprint-output.md
# Usage: sprint-export <sprint-file>
# Generates: product-context.md, claude-code-starter.md, pitch-summary.md

SPRINT_FILE="${1:?Usage: sprint-export <sprint-file>}"

if [ ! -f "$SPRINT_FILE" ]; then
  echo "ERROR: Sprint file not found: $SPRINT_FILE" >&2
  exit 1
fi

SPRINT_DIR=$(dirname "$SPRINT_FILE")

# Extract frontmatter to check completeness
STAGES=$(sed -n '/^---$/,/^---$/p' "$SPRINT_FILE" | grep 'stages_completed:' | sed 's/stages_completed: *\[//' | sed 's/\]//' | tr -d ' ')
STAGE_COUNT=$(echo "$STAGES" | tr ',' '\n' | grep -c '[0-9]' 2>/dev/null || echo "0")

if [ "$STAGE_COUNT" -lt 5 ]; then
  echo "WARNING: Only $STAGE_COUNT of 8 stages completed. Exports may be incomplete." >&2
fi

# Extract content (everything after the closing --- of YAML frontmatter)
# Find the line number of the second --- and take everything after it
FRONTMATTER_END=$(awk '/^---$/{n++; if(n==2){print NR; exit}}' "$SPRINT_FILE")
if [ -n "$FRONTMATTER_END" ]; then
  CONTENT=$(tail -n +"$((FRONTMATTER_END + 1))" "$SPRINT_FILE")
else
  CONTENT=$(cat "$SPRINT_FILE")
fi

# ── Helpers ──────────────────────────────────────────────────────────────
# extract_section <section_number>
#   Pulls content between "## <N>." and the next "## <digit>." header.
#   Tolerates minor header variations (extra spaces, trailing text).
extract_section() {
  local num="$1"
  awk -v n="$num" '
    /^## *[0-9]+\./ {
      # strip "## " prefix, then grab digits before the dot
      s = $0; sub(/^## */, "", s); sub(/\..*/, "", s); sec = s+0
      if (sec == n) { capture = 1; next }
      if (capture) { exit }
      next
    }
    capture { print }
  ' <<< "$CONTENT"
}

# extract_field <section_number> <substring>
#   Within a section, grab everything from a bold field label through the
#   next bold field or section header.  substring is matched
#   case-insensitively against each **Label:** line.
extract_field() {
  local num="$1"
  local pattern="$2"
  extract_section "$num" | awk -v pat="$pattern" '
    /^\*\*/ {
      low = tolower($0)
      lpat = tolower(pat)
      if (index(low, lpat) > 0) {
        capture = 1
        print
        next
      }
      if (capture) exit
    }
    capture { print }
  '
}

# ── 1. product-context.md ────────────────────────────────────────────────
{
cat << 'HEADER'
# Product Context

Generated by Design Sprint Assistant
Use this file to give Claude Code full context on what to build.

---

HEADER

echo "$CONTENT"

# Append "What NOT to Build" section from MVP Scope's "Explicitly NOT in v1"
NOT_V1=$(extract_field 5 "Explicitly NOT")
if [ -n "$NOT_V1" ]; then
  printf '\n---\n\n## What NOT to Build\n\n'
  echo "$NOT_V1"
fi
} > "$SPRINT_DIR/product-context.md"

echo "EXPORTED: $SPRINT_DIR/product-context.md"

# ── 2. claude-code-starter.md ───────────────────────────────────────────
{
cat << 'EOF'
# Claude Code Starter

Read `product-context.md` for full context on the product. Then follow
this implementation plan.

EOF

# Problem statement from section 2
PROBLEM=$(extract_section 2)
if [ -n "$PROBLEM" ]; then
  printf '## Problem\n\n%s\n\n' "$PROBLEM"
fi

# MVP features from section 5
MVP_FEATURES=$(extract_field 5 "must-have")
NOT_V1_STARTER=$(extract_field 5 "Explicitly NOT")
if [ -n "$MVP_FEATURES" ]; then
  printf '## MVP Features\n\n%s\n\n' "$MVP_FEATURES"
fi
if [ -n "$NOT_V1_STARTER" ]; then
  printf '## Out of Scope (v1)\n\n%s\n\n' "$NOT_V1_STARTER"
fi

# Tech stack from section 6
TECH_STACK=$(extract_field 6 "Tech stack")
if [ -n "$TECH_STACK" ]; then
  printf '## Tech Stack\n\n%s\n\n' "$TECH_STACK"
fi

# Build order from section 6
BUILD_ORDER=$(extract_field 6 "Build order")
if [ -n "$BUILD_ORDER" ]; then
  printf '## Build Order\n\n%s\n\n' "$BUILD_ORDER"
fi

# Assumptions & risks from section 7
ASSUMPTIONS=$(extract_section 7)
if [ -n "$ASSUMPTIONS" ]; then
  printf '## Assumptions & Risks\n\n%s\n\n' "$ASSUMPTIONS"
fi

# First session plan from section 8
SESSION_PLAN=$(extract_field 8 "First coding session")
if [ -n "$SESSION_PLAN" ]; then
  printf '## First Session Plan\n\n%s\n\n' "$SESSION_PLAN"
fi

# Additional context from section 8
EXTRA_CONTEXT=$(extract_field 8 "Additional context")
if [ -n "$EXTRA_CONTEXT" ]; then
  printf '## Additional Context\n\n%s\n\n' "$EXTRA_CONTEXT"
fi

cat << 'EOF'
## Instructions

1. Read product-context.md thoroughly before writing any code
2. Follow the Build Order above
3. Start with the First Session Plan
4. After each major component, check back against the MVP Features
5. Do NOT build anything listed in "Out of Scope (v1)"

## Priorities

- Get the magic moment working first
- Ship something usable, then iterate
- When in doubt, ask — don't assume

EOF
} > "$SPRINT_DIR/claude-code-starter.md"

echo "EXPORTED: $SPRINT_DIR/claude-code-starter.md"

# ── 3. pitch-summary.md ─────────────────────────────────────────────────
{
cat << 'HEADER'
# Pitch Summary

One-page summary generated by Design Sprint Assistant.

---

HEADER

# The Problem — from section 2
SEC2=$(extract_section 2)
printf '## The Problem\n\n'
if [ -n "$SEC2" ]; then
  echo "$SEC2"
else
  echo "_See product-context.md_"
fi
printf '\n'

# The Solution — from section 4
SEC4=$(extract_section 4)
printf '## The Solution\n\n'
if [ -n "$SEC4" ]; then
  echo "$SEC4"
else
  echo "_See product-context.md_"
fi
printf '\n'

# The MVP — from section 5
SEC5=$(extract_section 5)
printf '## The MVP\n\n'
if [ -n "$SEC5" ]; then
  echo "$SEC5"
else
  echo "_See product-context.md_"
fi
} > "$SPRINT_DIR/pitch-summary.md"

echo "EXPORTED: $SPRINT_DIR/pitch-summary.md"

echo "DONE: All exports generated in $SPRINT_DIR"
